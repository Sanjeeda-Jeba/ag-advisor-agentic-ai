# API Keys Configuration Template
# 
# INSTRUCTIONS:
# 1. Rename this file to: .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to git (it's already in .gitignore)

# OpenWeatherMap API Key
# Sign up at: https://openweathermap.org/api
# Free tier: 60 calls/minute
OPENWEATHER_API_KEY=your_openweather_api_key_here

# LLM Provider Configuration (provider-agnostic)
# Switch providers by changing these - no code changes needed
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_INTENT_MODEL=gpt-4o-mini   # Optional: faster/cheaper model for intent classification
# Console logs when each LLM client is created: "[LLM] Loaded client: provider=... model=... purpose=..."
# Set to true to hide those lines: LLM_SILENT_CLIENT_LOADS=true

# Provider-specific API keys (only the one for LLM_PROVIDER is required)
# OpenAI (when LLM_PROVIDER=openai) - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (when LLM_PROVIDER=anthropic)
# Sign up at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini (when LLM_PROVIDER=google)
# Sign up at: https://ai.google.dev
GOOGLE_API_KEY=your_google_api_key_here

# Legacy: OPENAI_MODEL_NAME still works when LLM_PROVIDER=openai (fallback for LLM_MODEL)
# OPENAI_MODEL_NAME=gpt-4o-mini

# Tavily API Key (for web search and CDMS label search)
# Sign up at: https://tavily.com
# Free tier: 1000 searches/month
TAVILY_API_KEY=your_tavily_api_key_here

# CDMS direct fetch (before Tavily). Install browsers: python -m playwright install chromium
# CDMS_DIRECT_SEARCH=true
# Prefer real Advanced Search UI (Playwright); falls back to HTML scrape if false/fails
# CDMS_DIRECT_USE_PLAYWRIGHT=true
# CDMS_PLAYWRIGHT_TIMEOUT_MS=25000
# CDMS_PLAYWRIGHT_STEP_MS=500
# HTML fallback (when Playwright misses)
# CDMS_DIRECT_MAX_PAGES=14
# CDMS_DIRECT_TIMEOUT=18
# CDMS_DIRECT_MAX_PDFS=12
# Optional comma-separated extra seed URLs to fetch first
# CDMS_DIRECT_EXTRA_URLS=
